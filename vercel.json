{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/nightly-predictions",
      "schedule": "0 1 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/predict.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/predict",
      "dest": "api/predict.py"
    }
  ]
}
