generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AppUser {
  id                String           @id @db.Uuid
  email             String           @unique
  role              Role             @default(USER)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  name              String?
  farmName          String?          @map("farm_name")
  fields            Field[]
  weatherAlerts     WeatherAlert[]
  todos             Todo[]
  creditBatchRuns   CreditBatchRun[]
  creditDecisions   CreditDecision[]

  @@map("app_users")
}

model Field {
  id                   String               @id @default(cuid())
  name                 String               @db.Text
  location             String               @default("Sin definir") @db.Text
  latitude             Float?               @db.DoublePrecision
  longitude            Float?               @db.DoublePrecision
  bboxMinLon           Float?               @map("bbox_min_lon") @db.DoublePrecision
  bboxMinLat           Float?               @map("bbox_min_lat") @db.DoublePrecision
  bboxMaxLon           Float?               @map("bbox_max_lon") @db.DoublePrecision
  bboxMaxLat           Float?               @map("bbox_max_lat") @db.DoublePrecision
  hectares             Int
  defaultCostPerHaUsd  Float                @default(0) @map("default_cost_per_ha_usd") @db.DoublePrecision
  score                Int                  @default(50)
  scoreTrend           Int                  @default(0) @map("score_trend")
  monthlyRevenueChange Float                @default(0) @map("monthly_revenue_change")
  revenueHistory       Json                 @map("revenue_history")
  yieldHistory         Json                 @map("yield_history")
  repayment            Json
  risk                 Json
  zone                 String               @default("Sin definir")
  userId               String               @map("user_id") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  predictionSnapshots  PredictionSnapshot[]
  creditDecisions      CreditDecision[]
  user                 AppUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertLinks           AlertField[]

  @@index([userId])
  @@index([createdAt])
  @@map("fields")
}

model PredictionSnapshot {
  id                  String   @id @default(cuid())
  fieldId             String   @map("field_id")
  startDate           String   @map("start_date") @db.Text
  endDate             String   @map("end_date") @db.Text
  predictedYieldTonHa Float    @map("predicted_yield_ton_ha") @db.DoublePrecision
  spotPriceUsdPerTon  Float    @map("spot_price_usd_per_ton") @db.DoublePrecision
  futuresContracts    Json     @map("futures_contracts")
  costPerHaUsd        Float    @map("cost_per_ha_usd") @db.DoublePrecision
  grossSpotUsd        Float    @map("gross_spot_usd") @db.DoublePrecision
  netSpotUsd          Float    @map("net_spot_usd") @db.DoublePrecision
  grossFuturesUsd     Json     @map("gross_futures_usd")
  netFuturesUsd       Json     @map("net_futures_usd")
  warning             String?  @db.Text
  source              String   @default("yahoo") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, createdAt])
  @@map("prediction_snapshots")
}

model WeatherAlert {
  id                 String       @id @default(cuid())
  userId             String       @map("user_id") @db.Uuid
  relevanceScore     Int          @default(0) @map("relevance_score")
  priorityScore      Int          @default(0) @map("priority_score")
  location           String       @db.Text
  latitude           Float?       @db.DoublePrecision
  longitude          Float?       @db.DoublePrecision
  description        String       @db.Text
  extractedVariables Json         @map("extracted_variables")
  issuedAt           DateTime     @default(now()) @map("issued_at") @db.Timestamptz(6)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  affectedFields     AlertField[]

  @@index([userId])
  @@index([issuedAt])
  @@map("weather_alerts")
}

model AlertField {
  alertId   String       @map("alert_id")
  fieldId   String       @map("field_id")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  alert     WeatherAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  field     Field        @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@id([alertId, fieldId])
  @@index([fieldId])
  @@map("alert_fields")
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  isDone    Boolean  @default(false) @map("is_done")
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      AppUser? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("todos")
}

enum Role {
  USER
  ADMIN
}

enum CreditRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CreditDecisionOutcome {
  APPROVED
  REJECTED
}

model CreditBatchRun {
  id            String                @id @default(cuid())
  runKey        String                @unique @map("run_key")
  engineVersion String                @map("engine_version")
  status        CreditRunStatus       @default(RUNNING)
  requestedById String?               @map("requested_by_id") @db.Uuid
  notes         String?
  requestedAt   DateTime              @default(now()) @map("requested_at") @db.Timestamptz(6)
  startedAt     DateTime              @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime?             @map("finished_at") @db.Timestamptz(6)
  fieldsChecked Int                   @default(0) @map("fields_checked")
  processed     Int                   @default(0)
  approved      Int                   @default(0)
  rejected      Int                   @default(0)
  skipped       Int                   @default(0)
  failed        Int                   @default(0)
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  requestedBy   AppUser?              @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  decisions     CreditDecision[]

  @@index([requestedById])
  @@index([requestedAt])
  @@index([status])
  @@map("credit_batch_runs")
}

model CreditDecision {
  id                   String                 @id @default(cuid())
  runId                String                 @map("run_id")
  fieldId              String                 @map("field_id")
  userId               String                 @map("user_id") @db.Uuid
  predictionSnapshotId String?                @map("prediction_snapshot_id")
  decision             CreditDecisionOutcome
  score                Float
  confidence           Float                  @default(0)
  decisionReason       String                 @map("decision_reason")
  reasonCodes          String[]               @default([]) @map("reason_codes")
  featureSnapshot      Json                   @map("feature_snapshot")
  sourceSnapshot       Json                   @map("source_snapshot")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  run                  CreditBatchRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  field                Field                  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  user                 AppUser                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, fieldId])
  @@index([fieldId])
  @@index([userId])
  @@index([decision])
  @@index([createdAt])
  @@map("credit_decisions")
}
