NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only. Do not expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by Prisma and to derive Supabase project URL on server-side.
DATABASE_URL="postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres"

# Optional but recommended on networks without IPv6.
# Use Supabase "Transaction pooler" connection string here.
DATABASE_URL_POOLER="postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require"
